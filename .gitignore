# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# =============================================================================
# Virtual environments
# =============================================================================
venv/
.venv/
env/
ENV/

# =============================================================================
# IDE & editor junk
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# =============================================================================
# OS junk
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Secrets -- NEVER commit these
# =============================================================================
.env
.env.*
*.key
*.pem
secrets.json
credentials.json
api_keys.txt

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Patch script backups (from the aisuite timeout patch)
# =============================================================================
*.bak
*.bak.*

# =============================================================================
# Project-specific: RUN OUTPUTS -- never commit these
# These folders fill with downloaded structures, docking outputs, and reports.
# They are large, generated, and often contain user-specific paths.
# =============================================================================
MultiAgent_Project/
Levetiracetam_Project/
*_Project/

# Leftover files from docking runs
*.pdbqt
*.sdf
*.pdb
*.log
*.xml
ligand_temp/
receptor_temp/
docking_temp/

# =============================================================================
# Reports and figures (generated)
# =============================================================================
reports/
figures/
*.png
*.jpg
*.jpeg
*.gif
# EXCEPTION: keep the screenshot in docs/
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.gif

# =============================================================================
# External tool binaries (if users drop them in the repo folder)
# =============================================================================
vina.exe
obabel.exe
*.dll

# =============================================================================
# Backup / scratch files
# =============================================================================
*.orig
*.rej
scratch/
temp/
tmp/
